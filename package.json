{
  "name": "remote-pilot",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:biome": "biome check .",
    "lint:biome:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "turbo run clean",
    "vsix": "pnpm --filter remote-pilot package"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "turbo": "^2.8.14",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.25.0"
}
