{
  "name": "remote-pilot",
  "displayName": "Remote Pilot",
  "description": "Remotely monitor and interact with VS Code Copilot chat sessions",
  "version": "0.0.1",
  "private": true,
  "publisher": "remote-pilot",
  "repository": {
    "type": "git",
    "url": "https://github.com/ilteoood/remote-pilot.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "remote-pilot.start",
        "title": "Remote Pilot: Start Server"
      },
      {
        "command": "remote-pilot.stop",
        "title": "Remote Pilot: Stop Server"
      },
      {
        "command": "remote-pilot.showPairingCode",
        "title": "Remote Pilot: Show Pairing Code"
      }
    ],
    "configuration": {
      "title": "Remote Pilot",
      "properties": {
        "remotePilot.serverPort": {
          "type": "number",
          "default": 3847,
          "description": "Port for the Remote Pilot server"
        },
        "remotePilot.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the server when VS Code opens"
        },
        "remotePilot.allowLan": {
          "type": "boolean",
          "default": false,
          "description": "Allow connections from LAN (not just localhost)"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown --config tsup.config.ts && node -e \"require('fs').cpSync(require.resolve('sql.js/dist/sql-wasm.wasm'), 'dist/sql-wasm.wasm')\"",
    "dev": "tsdown --config tsup.config.ts --watch",
    "prepackage": "mkdir -p dist/server dist/web && cp ../server/dist/index.cjs dist/server/index.js && cp -r ../web/dist/* dist/web/",
    "package": "vsce package --no-dependencies",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@remote-pilot/shared": "workspace:*",
    "sql.js": "^1.14.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.96.0",
    "@types/ws": "^8.18.0",
    "@vscode/vsce": "^3.7.1",
    "tsdown": "^0.10.0",
    "typescript": "^5.8.0"
  }
}
